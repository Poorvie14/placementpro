# ==========================================
# PlacementPro - Environment Configuration
# ==========================================

# 1. MongoDB Connection String (Required)
# Local: mongodb://localhost:27017/placementpro
# Production: Your MongoDB Atlas URI
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/placementpro?retryWrites=true&w=majority

# 2. Security (Required)
# Generate a secure key using: openssl rand -hex 32
SECRET_KEY=your_super_secret_jwt_key_here_change_in_production

# 3. Email Settings (Optional but required for mail notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp@gmail.com
# Use an App Password if using Gmail, not your account password
SMTP_PASSWORD=your_app_password
SMTP_FROM=PlacementPro <yourapp@gmail.com>

# 4. API & CORS Configuration
# Useful if deploying the frontend separately later
ALLOW_ORIGINS=http://localhost:5173,http://localhost:5174,*
